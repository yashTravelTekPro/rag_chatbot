# Python virtualenvs
.venv/
venv/
env/

# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class

# C extensions
*.so

# Distribution / packaging
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
share/python-wheels/
*.egg-info/
*.egg

# Installer logs
pip-log.txt
pip-delete-this-directory.txt

# Unit test / coverage reports
.tox/
*.cover
*.coverage
.coverage.*
.cache/
.pytest_cache/
htmlcov/
.hypothesis/

# pyenv
.python-version

# mypy
.mypy_cache/

# IDEs and editors
.vscode/
.idea/
*.sublime-project
*.sublime-workspace

# OS files
.DS_Store
Thumbs.db

# Environment / secrets
.env
env.local
secrets.env

# Data, indices and large files
data/indices/
data/*.index
data/*.db
data/*.idx

# Model and cache dirs (huggingface, torch, sentence-transformers)
models/
cache/
transformers_cache/
hf_cache/
sentence_transformers_cache/

# Logs
*.log
logs/

# Re-include app/data files that may be ignored by a parent repository .gitignore
!app/data/
!app/data/models.py
!app/data/stats_store.py

# Ignore all Python package initializer files (if that's intended)
__init__.py
